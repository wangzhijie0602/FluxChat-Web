{
  "openapi": "3.0.1",
  "info": {
    "title": "默认模块",
    "description": "",
    "version": "1.0.0"
  },
  "tags": [],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "用户注册",
        "deprecated": false,
        "description": "创建新用户账号并返回用户基础信息。",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest",
                "description": ""
              },
              "example": {
                "username": "jkafjiohgw",
                "email": "vdak5x_ffp66@hotmail.com",
                "password": "12345678a",
                "confirmPassword": "12345678a"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultUserProfile",
                  "description": "注册结果，成功时返回用户资料"
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "用户登录",
        "deprecated": false,
        "description": "使用账号与密码进行身份认证，认证通过后签发登录 Token。",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest",
                "description": ""
              },
              "example": {
                "account": "jkafjiohgw",
                "password": "12345678a"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultLoginResponse",
                  "description": "登录结果，成功时返回 Token 信息与用户资料"
                }
              }
            }
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "schemas": {
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "",
            "format": "int64"
          },
          "username": {
            "type": "string",
            "description": ""
          },
          "email": {
            "type": "string",
            "description": ""
          }
        }
      },
      "ResultUserProfile": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": ""
          },
          "message": {
            "type": "string",
            "description": ""
          },
          "data": {
            "$ref": "#/components/schemas/UserProfile",
            "description": ""
          },
          "timestamp": {
            "type": "integer",
            "description": "填充当前时间戳",
            "format": "int64"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": ""
          },
          "email": {
            "type": "string",
            "description": ""
          },
          "password": {
            "type": "string",
            "description": ""
          },
          "confirmPassword": {
            "type": "string",
            "description": ""
          }
        }
      },
      "SaTokenInfo": {
        "type": "object",
        "properties": {
          "tokenName": {
            "type": "string",
            "description": "token 名称"
          },
          "tokenValue": {
            "type": "string",
            "description": "token 值"
          },
          "isLogin": {
            "type": "boolean",
            "description": "此 token 是否已经登录"
          },
          "loginId": {
            "type": "object",
            "properties": {},
            "description": "此 token 对应的 LoginId，未登录时为 null"
          },
          "loginType": {
            "type": "string",
            "description": "多账号体系下的账号类型"
          },
          "tokenTimeout": {
            "type": "integer",
            "description": "token 剩余有效期（单位: 秒）",
            "format": "int64"
          },
          "sessionTimeout": {
            "type": "integer",
            "description": "Account-Session 剩余有效时间（单位: 秒）",
            "format": "int64"
          },
          "tokenSessionTimeout": {
            "type": "integer",
            "description": "Token-Session 剩余有效时间（单位: 秒）",
            "format": "int64"
          },
          "tokenActiveTimeout": {
            "type": "integer",
            "description": "token 距离被冻结还剩多少时间（单位: 秒）",
            "format": "int64"
          },
          "loginDeviceType": {
            "type": "string",
            "description": "登录设备类型"
          },
          "tag": {
            "type": "string",
            "description": "自定义数据（暂无意义，留作扩展）"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "tokenInfo": {
            "$ref": "#/components/schemas/SaTokenInfo",
            "description": ""
          },
          "user": {
            "$ref": "#/components/schemas/UserProfile",
            "description": ""
          }
        }
      },
      "ResultLoginResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": ""
          },
          "message": {
            "type": "string",
            "description": ""
          },
          "data": {
            "$ref": "#/components/schemas/LoginResponse",
            "description": ""
          },
          "timestamp": {
            "type": "integer",
            "description": "填充当前时间戳",
            "format": "int64"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "account": {
            "type": "string",
            "description": ""
          },
          "password": {
            "type": "string",
            "description": ""
          }
        }
      }
    },
    "responses": {},
    "securitySchemes": {}
  },
